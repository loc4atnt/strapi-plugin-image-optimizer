{
  "extends": "@strapi/typescript-utils/tsconfigs/server",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    // Override base "module: CommonJS" so `await import('@jsquash/*')` is preserved
    // as a real dynamic import. The `@jsquash/*` packages are pure ESM and
    // require()-ing them throws ERR_REQUIRE_ESM at runtime.
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022"
  },
  "include": [
    // Include the root directory
    "server",
    // Force the JSON files in the src folder to be included
    "server/**/*.json"
  ],
  "exclude": [
    "node_modules/",
    "dist/",
    // Do not include admin files in the server compilation
    "admin/",
    // Do not include test files
    "**/*.test.ts"
  ]
}
